# Managed by Ansible - do not edit manually

# Local domain
domain={{ dns_domain }}
local=/{{ dns_domain }}/
expand-hosts

# Upstream DNS for non-local queries
server={{ dns_upstream }}

# Don't read /etc/resolv.conf
no-resolv

# Listen on localhost and the server's IP
listen-address=127.0.0.1
listen-address={{ dns_server_ip }}
bind-interfaces

# Additional hosts file for local entries
addn-hosts=/etc/hosts.{{ dns_domain }}

# Cache size
cache-size=1000

# Don't forward plain names (without dots)
domain-needed

# Don't forward addresses in non-routed spaces
bogus-priv
